    "render:all": "bash scripts/render-all.sh",
    "new-week": "bash scripts/new-week.sh",
    "og": "python3 scripts/build-og-image.py",
    "stats": "node scripts/daily-stats.mjs",
    "citation-audit": "node scripts/citation-audit.mjs",
