{
  "name": "agent-quotidien",
  "version": "1.0.0",
  "description": "L'Agent & Le Quotidien — hebdomadaire bilingue (FR/EN) de journalisme sur l'internet agentique. Atelier ouvert : prompts, scripts, données et statistiques publics.",
  "type": "module",
  "private": true,
  "homepage": "https://theagentweekly.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeb-maker/lagent-quotidien.git"
  },
  "bugs": {
    "url": "https://github.com/jeb-maker/lagent-quotidien/issues"
  },
  "keywords": [
    "agentic-ai",
    "ai-agents",
    "ai-generated-content",
    "bluesky",
    "claude-code",
    "cloudflare-pages",
    "prompt-engineering",
    "ai-journalism",
    "sourced-journalism"
  ],
  "scripts": {
    "render": "node render.mjs",
    "render:workshop": "node scripts/render-workshop-page.mjs",
    "lint:edition": "node scripts/lint-edition.mjs",
    "lint:strict": "node scripts/lint-edition.mjs --strict",
    "validate:schema": "node scripts/validate-edition-schema.mjs",
